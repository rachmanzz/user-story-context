#!/usr/bin/env bash
# usc — User Story Context CLI
# Scaffold project structure for a new feature

set -euo pipefail

COMMAND="${1:-help}"
FEATURE_NAME="${2:-}"
BASE_DIR="${USC_DIR:-$(pwd)}"

usage() {
  cat <<EOF
Usage: usc <command> [feature-name]

Commands:
  init <name>   Scaffold a new feature with template files
  list          List all features in current directory
  help          Show this help

Examples:
  usc init login
  usc init checkout-payment
EOF
}

init_feature() {
  if [[ -z "$FEATURE_NAME" ]]; then
    echo "Error: feature name required"
    usage
    exit 1
  fi

  TARGET="$BASE_DIR/$FEATURE_NAME"

  if [[ -d "$TARGET" ]]; then
    echo "Error: '$FEATURE_NAME' already exists at $TARGET"
    exit 1
  fi

  mkdir -p "$TARGET/includes"

  cat > "$TARGET/user-story.md" <<-MD
# $FEATURE_NAME — User Story Map

> Generated: $(date +%Y-%m-%d)
> Feature: $FEATURE_NAME

## Project Overview

| Field | Description |
|-------|-------------|
| **Product** | |
| **Problem** | |
| **Target Users** | |
| **Timeline** | |

## Table of Contents

| # | Category | File | Description |
|---|----------|------|-------------|
| 1 | Epics | [includes/epics.md](includes/epics.md) | Epic definitions & business goals |
| 2 | User Stories | [includes/user-stories.md](includes/user-stories.md) | All user stories |
| 3 | Acceptance Criteria | [includes/acceptance-criteria.md](includes/acceptance-criteria.md) | AC per story |
| 4 | BDD Scenarios | [includes/bdd-scenarios.md](includes/bdd-scenarios.md) | Gherkin scenarios |
| 5 | Technical Notes | [includes/technical-notes.md](includes/technical-notes.md) | Architecture & constraints |
| 6 | UX Notes | [includes/ux-notes.md](includes/ux-notes.md) | Design & UX decisions |
| 7 | Glossary | [includes/glossary.md](includes/glossary.md) | Domain terms |

## Quick Reference

| ID | Epic | Priority | Stories | Link |
|----|------|----------|---------|------|
| EPIC-1 | TBD | — | TBD | [details](includes/epics.md) |
MD

  for FILE in epics user-stories acceptance-criteria bdd-scenarios technical-notes ux-notes glossary; do
    cat > "$TARGET/includes/${FILE}.md" <<-MD
# ${FILE}

---

_(Generated by AI after Q&A session)_
MD
  done

  cat > "$TARGET/jira-import.csv" <<-CSV
Summary,Issue Type,Priority,Description,Acceptance Criteria,Epic Link,Labels
CSV

  cat > "$TARGET/github-issues.json" <<-JSON
[]
JSON

  echo "✓ Scaffolded '$FEATURE_NAME' at $TARGET"
  echo "  Directory: $TARGET"
  echo "  Files:"
  echo "    - user-story.md"
  for f in includes/epics.md includes/user-stories.md includes/acceptance-criteria.md includes/bdd-scenarios.md includes/technical-notes.md includes/ux-notes.md includes/glossary.md; do
    echo "    - $f"
  done
  echo "    - jira-import.csv"
  echo "    - github-issues.json"
  echo ""
  echo "  Next: Buka AI assistant, paste .ai-context/system-prompt.md,"
  echo "  lalu mulai dengan: 'Isi user story untuk feature $FEATURE_NAME'"
}

list_features() {
  echo "Features in $BASE_DIR:"
  find "$BASE_DIR" -mindepth 1 -maxdepth 1 -type d | while read -r dir; do
    name=$(basename "$dir")
    if [[ -f "$dir/user-story.md" ]]; then
      echo "  ✓ $name"
    fi
  done
}

case "$COMMAND" in
  init)
    init_feature
    ;;
  list)
    list_features
    ;;
  help|--help|-h)
    usage
    ;;
  *)
    echo "Unknown command: $COMMAND"
    usage
    exit 1
    ;;
esac
